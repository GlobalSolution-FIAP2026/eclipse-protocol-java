{
  "info": {
    "name": "EclipseProtocol API",
    "_postman_id": "eclipse-protocol-collection",
    "description": "Coleção completa da API EclipseProtocol - FIAP\n\nOrdem sugerida para testar:\n1. POST /usuarios\n2. POST /localizacoes\n3. POST /propriedades (usa idUsuario + idLocalizacao)\n4. POST /plantacoes (usa idPropriedade)\n5. POST /sensores (usa idPlantacao)\n6. POST /leituras (usa idSensor)\n7. POST /alertas (usa idLeitura + idPlantacao)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
